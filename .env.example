# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL="mysql://username:password@localhost:3306/attendance_db"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# API Key for Device Webhooks
API_KEY="your-secure-api-key-change-in-production"

# ==========================================
# ZKTeco K60 Device - POLLING CONFIGURATION
# ==========================================
# Use this if your device doesn't support ADMS

# Device IP Address (Required for polling)
K60_IP="192.168.1.100"

# Device Connection Port (Default: 4370)
K60_PORT=4370

# Device Identifier in System
K60_DEVICE_ID="ZK-001"

# Device Display Name
K60_DEVICE_NAME="Main Office K60"

# Polling Interval in milliseconds (Default: 60000 = 1 minute)
K60_POLL_INTERVAL_MS=60000

# Check-in Status Codes (devices report these for check-in)
# Common values: 0 (Normal), 4 (OT In)
K60_CHECKIN_STATUSES="0,4,8"

# Check-out Status Codes (devices report these for check-out)
# Common value: 1 (Out)
K60_CHECKOUT_STATUSES="1"
# ==========================================
# AUTOMATIC ATTENDANCE CRON JOB
# ==========================================

# Enable/Disable automatic check-in/out (true/false)
ENABLE_CRON=true

# Automatic Check-in Time (24-hour format: HH:mm)
CHECK_IN_TIME="09:00"

# Automatic Check-out Time (24-hour format: HH:mm)
CHECK_OUT_TIME="17:00"

# Timezone for Cron Jobs (use standard timezone names)
CRON_TIMEZONE="Asia/Karachi"